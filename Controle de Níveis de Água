from colorama import Fore, Style, init

# Inicializa o colorama
init(autoreset=True)

# Lista de níveis e mensagens
niveis = [
    ("Muito baixo (crítico)", Fore.RED),
    ("Baixo", Fore.YELLOW),
    ("Médio", Fore.GREEN),
    ("Alto", Fore.CYAN),
    ("Muito alto (alerta)", Fore.BLUE)
]

# Função para exibir situação conforme nível
def exibir_situacao(nivel):
    if 1 <= nivel <= 5:
        mensagem, cor = niveis[nivel - 1]
        print(cor + f"Nível {nivel}: {mensagem}" + Style.RESET_ALL)
    else:
        print(Fore.MAGENTA + "Nível inválido!" + Style.RESET_ALL)

# Simulação dos níveis do reservatório
for nivel in range(1, 6):
    exibir_situacao(nivel)
